# PostgreSQL used by Prisma.
DATABASE_URL="postgresql://polymind:polymind_dev_password@localhost:5432/polymind?schema=public"

# AES-256-GCM key for encrypting user Provider API Keys.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# Temporary demo user used until a real auth provider is connected.
DEMO_USER_EMAIL="demo@polymind.local"
DEMO_USER_NAME="PolyMind Demo User"

# Public app URL for links and metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
